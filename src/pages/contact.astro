---
import BaseLayout from '../layouts/BaseLayout.astro';

const sent = Astro.url.searchParams.get('sent');
---
<BaseLayout title="お問い合わせ" description="ご質問・ご依頼はこちらからお気軽にどうぞ。">
  <h1 class="page-title">お問い合わせ</h1>

  {sent === 'true' ? (
    <div class="success-box">
      <p>✅ メッセージを送信しました。ありがとうございます！<br />数日以内にご返信いたします。</p>
    </div>
  ) : (
    <div class="form-wrap">
      <p class="form-desc">ご質問・ご依頼・感想などお気軽にどうぞ。</p>
      <form
        action="https://formspree.io/f/xdavwvdp"
        method="POST"
      >
        <input type="hidden" name="_next" value={`${Astro.url.origin}/contact?sent=true`} />

        <div class="field">
          <label for="name">お名前</label>
          <input type="text" id="name" name="name" required placeholder="山田 太郎" />
        </div>

        <div class="field">
          <label for="email">メールアドレス</label>
          <input type="email" id="email" name="email" required placeholder="example@email.com" />
        </div>

        <div class="field">
          <label for="message">メッセージ</label>
          <textarea id="message" name="message" required rows="6" placeholder="メッセージを入力してください"></textarea>
        </div>

        <button type="submit" class="submit-btn">送信する</button>
      </form>
    </div>
  )}
</BaseLayout>

<style>
  .page-title { font-size: 1.6rem; margin-bottom: 1.5rem; }

  .success-box {
    background: #f0fff4;
    border: 1px solid #68d391;
    border-radius: 8px;
    padding: 1.5rem;
    color: #276749;
    line-height: 1.8;
  }

  .form-wrap { max-width: 560px; }
  .form-desc { color: #666; margin-bottom: 1.5rem; font-size: 0.95rem; }

  .field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.25rem; }
  label { font-size: 0.9rem; font-weight: bold; color: #444; }

  input, textarea {
    border: 1px solid #ddd;
    border-radius: 6px;
    padding: 0.65rem 0.85rem;
    font-size: 1rem;
    font-family: inherit;
    width: 100%;
    background: #fff;
    transition: border-color 0.2s;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: #0070f3;
    box-shadow: 0 0 0 3px rgba(0,112,243,0.1);
  }
  textarea { resize: vertical; }

  .submit-btn {
    background: #0070f3;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 0.75rem 2rem;
    font-size: 1rem;
    cursor: pointer;
    width: 100%;
    transition: background 0.2s;
  }
  .submit-btn:hover { background: #0058c4; }

  @media (max-width: 600px) {
    .page-title { font-size: 1.35rem; }
  }
</style>
