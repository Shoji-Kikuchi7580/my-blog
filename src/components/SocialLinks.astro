const entries = Object.entries(social).filter(([_, url]) => url && url.startsWith('http'));
---

<div class={`social-links social-links--${size}`}>
  {entries.map(([key, url]) => (
    <a href={url} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={key} set:html={`<span class="icon-wrap">${icons[key] ?? ''}</span>`} />
  ))}
</div>

<style>
  .social-links { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #f0f4ff;
    color: #555;
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }
  .social-link:hover { background: #0070f3; color: #fff; }

  .social-links--md .social-link { width: 40px; height: 40px; }
  .social-links--sm .social-link { width: 32px; height: 32px; }

  .social-link :global(svg) { display: block; }
  .social-link :global(.icon-wrap) { display: flex; align-items: center; justify-content: center; }
</style>
