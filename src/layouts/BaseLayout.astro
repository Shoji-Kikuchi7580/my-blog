---
import { getProfile } from '../lib/profile';

interface Props {
  title: string;
  description?: string;
}

const profile = getProfile();
const { title, description = profile.siteDescription } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title} | {profile.siteTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | ${profile.siteTitle}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="alternate" type="application/rss+xml" title={profile.siteTitle} href="/rss.xml" />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', sans-serif; color: #333; background: #fafafa; line-height: 1.8; font-size: 16px; }
      a { color: #0070f3; text-decoration: none; }
      a:hover { text-decoration: underline; }
      img { max-width: 100%; height: auto; display: block; }

      header { background: #fff; border-bottom: 1px solid #eee; padding: 0.9rem 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
      header .logo { font-size: 1.3rem; font-weight: bold; color: #333; flex-shrink: 0; }
      nav { display: flex; flex-wrap: wrap; gap: 0.25rem 1rem; }
      nav a { color: #555; font-size: 0.9rem; padding: 0.3rem 0; min-height: 44px; display: flex; align-items: center; }

      main { max-width: 800px; margin: 1.5rem auto; padding: 0 1rem; }

      footer { text-align: center; padding: 2rem 1rem; color: #999; font-size: 0.85rem; border-top: 1px solid #eee; margin-top: 3rem; }
      footer nav { justify-content: center; margin-bottom: 0.75rem; gap: 0.5rem 1.25rem; }
      footer nav a { font-size: 0.85rem; color: #999; min-height: auto; }

      @media (max-width: 600px) {
        body { font-size: 15px; }
        header { padding: 0.75rem 1rem; }
        header .logo { font-size: 1.15rem; }
        nav a { font-size: 0.85rem; }
        main { margin: 1rem auto; padding: 0 0.875rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <a class="logo" href="/">{profile.siteTitle}</a>
      <nav>
        <a href="/">記事一覧</a>
        <a href="/tags">タグ一覧</a>
        <a href="/about">プロフィール</a>
        <a href="/contact">お問い合わせ</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <nav>
        <a href="/about">プロフィール</a>
        <a href="/contact">お問い合わせ</a>
        <a href="/privacy">プライバシーポリシー</a>
        <a href="/rss.xml">RSS</a>
      </nav>
      <p>© 2026 {profile.siteTitle}</p>
    </footer>
  </body>
</html>
